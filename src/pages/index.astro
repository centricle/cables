---
import BaseLayout from '../layouts/BaseLayout.astro';
import CableCard from '../components/CableCard.astro';
import IdentifyCTA from '../components/IdentifyCTA.astro';
import { getAllCategories } from '../utils/cableData';

const categories = getAllCategories();
---

<BaseLayout>
  <!-- Hero Section -->
  <div class="bg-primary">
    <div class="max-w-5xl mx-auto px-4 py-16">
      <div class="text-center">
        <h1 class="text-4xl font-bold sm:text-5xl md:text-6xl text-balance">
          Cable & Connector Database
        </h1>
        <p class="mt-6 max-w-2xl mx-auto">
          Cable and connector specifications. Pinouts, data rates, power delivery, compatibility.
        </p>
        <div class="mt-8">
          <form method="GET" action="/search" class="flex justify-center" role="search" aria-label="Search cables">
            <div class="relative w-full max-w-lg">
              <input
                type="search"
                name="q"
                placeholder="Search cables (e.g. USB-C, Thunderbolt 4, 40 Gbps)..."
                aria-label="Search cable database"
                class="w-full px-4 py-3 pr-12 text-foreground bg-card border-0 rounded-xl shadow-lg focus:ring-2 focus:ring-primary-foreground/30 focus:outline-none"
              />
              <button
                type="submit"
                aria-label="Search cables"
                class="absolute right-3 top-1/2 transform -translate-y-1/2 hover:transition-colors"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <circle cx="11" cy="11" r="8" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m21 21-4.34-4.34"/>
                </svg>
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

  <IdentifyCTA />

  <!-- Main Content -->
  <div class="max-w-5xl mx-auto px-4 pt-12 pb-16">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-foreground mb-4">Connector Categories</h2>
      <p class="max-w-2xl mx-auto">
        Browse connectors by category or search for specific types. All data is sourced from official specifications and standards bodies.
      </p>
    </div>

    <div class="space-y-16">
      {categories.map((category) => (
        <section>
          <div class="mb-8">
            <div class="flex justify-between items-center">
              <h3 class="text-2xl font-bold text-foreground">{category.name}</h3>
              {category.cables.length > 0 && (
                <a
                  href={`/${category.slug}`}
                  class="btn btn-secondary"
                >
                  View All →
                </a>
              )}
            </div>
            <p class="mt-2">{category.description}</p>
          </div>

          {category.cables.length > 0 ? (
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {category.cables.slice(0, 3).map((cable) => (
                <CableCard cable={cable} category={category.slug} />
              ))}
            </div>
          ) : (
            <div class="text-center py-8 border border-dashed border-border rounded-2xl">
              Coming soon
            </div>
          )}
        </section>
      ))}
    </div>

    <!-- Key Facts Section -->
    <section class="mt-16 rounded-2xl border border-border bg-card p-8">
      <h2 class="mb-6 text-xl font-semibold text-foreground">
        Key Facts
      </h2>
      <div class="grid gap-6 sm:grid-cols-3">
        <div class="flex flex-col gap-2">
          <h3 class="font-medium text-foreground mb-0">Connector ≠ Protocol</h3>
          <p class="text-sm leading-relaxed mb-0">
            A USB-C connector can carry USB 2.0 (480 Mbps), USB4 (40 Gbps), Thunderbolt 4 (40 Gbps), or DisplayPort 2.1. The physical plug does not determine the protocol.
          </p>
        </div>
        <div class="flex flex-col gap-2">
          <h3 class="font-medium text-foreground mb-0">Cable Ratings Vary</h3>
          <p class="text-sm leading-relaxed mb-0">
            Two USB-C cables with identical connectors can differ in data rate (480 Mbps vs 40 Gbps), power delivery (60W vs 240W), and video support. Ratings are cable-specific, not connector-specific.
          </p>
        </div>
        <div class="flex flex-col gap-2">
          <h3 class="font-medium text-foreground mb-0">Asymmetric Cables Exist</h3>
          <p class="text-sm leading-relaxed mb-0">
            Many cables have different connectors on each end (USB-A to USB-C, HDMI to DisplayPort). The combination determines which signals the cable can carry.
          </p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
